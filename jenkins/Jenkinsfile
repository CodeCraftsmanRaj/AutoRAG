def ragPipeline

pipeline {
	agent any

	options {
		disableConcurrentBuilds()
		buildDiscarder(logRotator(numToKeepStr: '30'))
	}

	environment {
		APP_NAME = 'auto-rag'
		IMAGE_REPO = 'ghcr.io/your-org/auto-rag'
		IMAGE_TAG = "${env.GIT_COMMIT ? env.GIT_COMMIT.take(7) : env.BUILD_ID}"
		RAG_SCORE_THRESHOLD = '0.75'
		HELM_RELEASE = 'auto-rag'
		K8S_NAMESPACE = 'rag'
		TF_DIR = 'infra/terraform'
		PYTHONPATH = 'rag-app'
	}

	stages {
		stage('Checkout') {
			steps {
				checkout scm
			}
		}

		stage('Load Shared Library Script') {
			steps {
				script {
					ragPipeline = load 'jenkins/shared-library/vars/ragPipeline.groovy'
					env.SONAR_ENABLED = 'false'
				}
			}
		}

		stage('SonarQube Scan') {
			steps {
				script {
					if (env.SONAR_HOST_URL?.trim() && env.SONAR_TOKEN?.trim()) {
						sh '''
							set -e
							cd rag-app
							python -m pip install --upgrade pip
							pip install -r requirements.txt
							sonar-scanner \
								-Dsonar.projectKey=auto-rag \
								-Dsonar.sources=app \
								-Dsonar.tests=tests \
								-Dsonar.python.version=3.11 \
								-Dsonar.host.url=${SONAR_HOST_URL} \
								-Dsonar.token=${SONAR_TOKEN}
						'''
						env.SONAR_ENABLED = 'true'
					} else {
						echo 'Skipping SonarQube scan: set SONAR_HOST_URL and SONAR_TOKEN in Jenkins job environment to enable.'
					}
				}
			}
		}

		stage('SonarQube Quality Gate') {
			when {
				expression { env.SONAR_ENABLED == 'true' }
			}
			steps {
				sh '''
					set -e
					REPORT_FILE="rag-app/.scannerwork/report-task.txt"
					if [ ! -f "$REPORT_FILE" ]; then
						echo "Sonar report not found: $REPORT_FILE"
						exit 1
					fi

					CE_TASK_URL=$(grep '^ceTaskUrl=' "$REPORT_FILE" | cut -d'=' -f2-)
					if [ -z "$CE_TASK_URL" ]; then
						echo "ceTaskUrl not found in report-task.txt"
						exit 1
					fi

					echo "Waiting for SonarQube compute task..."
					for i in $(seq 1 60); do
						STATUS=$(curl -s -u "${SONAR_TOKEN}:" "$CE_TASK_URL" | python -c 'import sys, json; print(json.load(sys.stdin)["task"]["status"])')
						echo "CE task status: $STATUS"
						if [ "$STATUS" = "SUCCESS" ]; then
							break
						fi
						if [ "$STATUS" = "FAILED" ] || [ "$STATUS" = "CANCELED" ]; then
							echo "SonarQube compute task failed: $STATUS"
							exit 1
						fi
						sleep 5
					done

					QG_STATUS=$(curl -s -u "${SONAR_TOKEN}:" "${SONAR_HOST_URL}/api/qualitygates/project_status?projectKey=auto-rag" | python -c 'import sys, json; print(json.load(sys.stdin)["projectStatus"]["status"])')
					echo "Quality Gate status: $QG_STATUS"
					[ "$QG_STATUS" = "OK" ]
				'''
			}
		}

		stage('Build and Push Image') {
			steps {
				script {
					ragPipeline.buildAndPushImage(
						imageRepo: env.IMAGE_REPO,
						imageTag: env.IMAGE_TAG,
						dockerContext: 'rag-app',
						dockerfilePath: 'rag-app/Dockerfile',
						credentialsId: 'ghcr-creds'
					)
				}
			}
		}

		stage('RAG Evaluation Gate') {
			steps {
				script {
					ragPipeline.evaluateRAG(
						appDir: 'rag-app',
						threshold: env.RAG_SCORE_THRESHOLD
					)
				}
			}
		}

		stage('Terraform Apply (if needed)') {
			when {
				expression {
					return sh(script: "git diff --name-only HEAD~1 HEAD | grep '^infra/terraform/' || true", returnStdout: true).trim()
				}
			}
			steps {
				script {
					ragPipeline.applyTerraform(tfDir: env.TF_DIR)
				}
			}
		}

		stage('Deploy via Helm') {
			steps {
				script {
					ragPipeline.deployHelm(
						releaseName: env.HELM_RELEASE,
						chartPath: 'helm/rag-chart',
						namespace: env.K8S_NAMESPACE,
						imageRepo: env.IMAGE_REPO,
						imageTag: env.IMAGE_TAG
					)
				}
			}
		}

		stage('Post-deploy Reindex') {
			when {
				expression {
					return sh(script: 'command -v kubectl >/dev/null 2>&1', returnStatus: true) == 0
				}
			}
			steps {
				sh '''
					set -e
					kubectl -n ${K8S_NAMESPACE} rollout status deploy/${HELM_RELEASE}-rag --timeout=180s
					POD=$(kubectl -n ${K8S_NAMESPACE} get pods -l app.kubernetes.io/name=rag-chart -o jsonpath='{.items[0].metadata.name}')
					kubectl -n ${K8S_NAMESPACE} exec "$POD" -- \
						curl -sS -X POST http://localhost:8000/ingest \
						-H "Content-Type: application/json" \
						-d '{"paths":["/app/docs"],"rebuild":true}'
				'''
			}
		}
	}

	post {
		success {
			echo "Build passed and deployed: ${IMAGE_REPO}:${IMAGE_TAG}"
		}
		failure {
			echo 'Build failed. Check stage logs for the exact blocking step.'
		}
	}
}

